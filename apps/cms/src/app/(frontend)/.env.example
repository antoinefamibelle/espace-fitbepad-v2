NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public contact (SEO JSON-LD, footer, etc.). Falls back in code if unset.
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=

# Public URL used by existing client-side API utilities.
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Payload CMS base URL for server-side bridge routes.
PAYLOAD_CMS_URL=http://localhost:3001

# Payload service credential used by server routes.
# Use "Bearer <token>" or "<collection> API-Key <key>".
PAYLOAD_SERVICE_TOKEN=

# Shared secret must match apps/cms BRIDGE_INTERNAL_SECRET.
BRIDGE_INTERNAL_SECRET=replace-with-shared-bridge-secret

# Session signing secret for client auth cookie.
AUTH_SESSION_SECRET=replace-with-a-long-random-secret

# Google OAuth credentials for social login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
